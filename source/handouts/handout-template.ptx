<?xml version="1.0" encoding="UTF-8"?>

<worksheet>
<title>Handout Title</title>

  <page>
    <p workspace="1in">
      A first paragraph with some space for notes below it.
    </p>

    <image width="50%">
      <prefigure xmlns="https://prefigure.org"
        label="another-prefigure">
        <diagram dimensions="(300, 300)" margins="5">
          <coordinates bbox="(-1,-1,4,4)">
            <definition>v1=(2,1)</definition>
            <definition>v2=(1,2)</definition>
            <grid basis="(v1,v2)" stroke="lightgray"/>
            <axes/>
            <vector v="v1"><m>{\mathbf v}_1</m></vector>
            <vector v="v2"><m>{\mathbf v}_2</m></vector>
          </coordinates>
        </diagram>
      </prefigure>
    </image>

    <figure xml:id="fig-prefig">
      <caption>A graph</caption>
      <image width="60%">
        <prefigure label="prefig" xmlns="https://prefigure.org">
          <diagram dimensions="(300, 300)" margins="5">
            <definition>f(x)=x^2-3</definition>
            <coordinates bbox="(-4,-4,4,4)">
              <grid-axes decorations="yes"/>
              <graph function="f"/>
            </coordinates>
          </diagram>
        </prefigure>
      </image>
    </figure>

    <image width="80%" source="images/sofia.png"/>

  </page>
</worksheet>
