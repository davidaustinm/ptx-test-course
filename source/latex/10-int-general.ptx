<?xml version="1.0" encoding="UTF-8"?>
<worksheet>
  <title>Antidifferentiation Practice</title>

  <exercise workspace="1.85in">
    <statement>
      <p><m>\displaystyle
\int\frac{1}{t^2 - 1}~dt 
</m></p>
    </statement>
  </exercise>

  <exercise workspace="1.85in">
    <statement>
      <p><m>\displaystyle
\int \frac{x}{x^2 - 1}~dx</m></p>
    </statement>
  </exercise>

  <exercise workspace="1.85in">
    <statement>
      <p><m>\displaystyle
\int x^2(2x^3 - 1)^3~dx 
</m></p>
    </statement>
  </exercise>

  <exercise workspace="2in">
    <statement>
      <p><m>\displaystyle
\int\frac1{1+t^2}~dt 
</m></p>
    </statement>
  </exercise>

  <exercise workspace="2in">
    <statement>
      <p><m>\displaystyle
\int z^2 e^{2z}~dz 
</m></p>
    </statement>
  </exercise>

  <exercise workspace="2in">
    <statement>
      <p><m>\displaystyle
\int \frac{1}{x^2-x}~dx</m></p>
    </statement>
  </exercise>

  <exercise workspace="2in">
    <statement>
      <p><m>\displaystyle
\int \ln x~dx 
</m></p>
    </statement>
  </exercise>

  <exercise workspace="2in">
    <statement>
      <p><m>\displaystyle
\int x\cos x~dx
</m></p>
    </statement>
  </exercise>

  <exercise workspace="2in">
    <statement>
      <p><m>\displaystyle
\int\frac{e^{2x}}{e^{2x} + 1}~dx
</m></p>
    </statement>
  </exercise>

  <exercise workspace="2in">
    <statement>
      <p><m>\displaystyle
\int t\ln t~dt 
</m></p>
    </statement>
  </exercise>

  <exercise workspace="1in">
    <statement>
      <p><m>\displaystyle
\int \cos^2\theta\sin\theta~d\theta
</m></p>
    </statement>
  </exercise>

</worksheet>
